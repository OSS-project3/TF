# OpenAI 연동 — 이 파일을 .env 로 복사한 뒤 키를 채우세요. (cp .env.example .env)
# 키가 있으면 AI 작업 분해 / 회의 요약이 실제 OpenAI로 동작합니다.
# 비워 두면 AI 기능은 비활성(프론트는 자동으로 템플릿 폴백)됩니다.
OPENAI_API_KEY={}
# 사용할 모델 (기본: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# 메일 설정
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME={}
MAIL_PASSWORD={}

# 앱 기본 URL
APP_BASE_URL=http://localhost:3000

# Google OAuth 클라이언트 ID
VITE_GOOGLE_CLIENT_ID={}
GOOGLE_CLIENT_ID={}
